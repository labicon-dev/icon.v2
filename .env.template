# Template de variáveis de ambiente do site do ICON.
#
# Copie este arquivo para `.env.local` e preencha os valores reais:
#     cp .env.template .env.local
#
# `.env.local` é gitignored — NUNCA commite valores reais. A própria URL da
# API é tratada como segredo: preencha localmente e, em CI/deploy, use os
# secrets do ambiente (GitHub Actions Secrets, env vars do Vercel/servidor).

# URL base da API do laboratório (ex.: https://.../api/v2 — obtida com o time,
# nunca versionada). O client HTTP lê sempre desta variável.
VITE_API_BASE_URL=
